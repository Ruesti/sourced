# Copy to .env.local for local dev. On Vercel, set these in Project → Settings → Environment Variables.

# Supabase (optional — app works offline in the browser without these)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side API proxies (optional)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# TAVILY_API_KEY=
# NEXAR_CLIENT_ID=
# NEXAR_CLIENT_SECRET=

# ── Author / distribution strip (https only) ───────────────────────────────
# Shown under the app header when at least one URL is set — drives visitors to your site.
# NEXT_PUBLIC_CREATOR_SITE_URL=https://example.com
# NEXT_PUBLIC_CREATOR_SITE_LABEL=Meine Projekte
# NEXT_PUBLIC_DOWNLOAD_PAGE_URL=https://example.com/sourced
# NEXT_PUBLIC_CREATOR_STRIP_NOTE=ZIP und Updates gibt es auf meiner Seite.
